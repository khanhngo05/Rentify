rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper functions ───────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ─── users ──────────────────────────────────────────────────────
    // - Ai đã đăng nhập đều đọc được (để hiển thị tên người đánh giá)
    // - Chỉ chủ tài khoản hoặc admin mới sửa/xóa
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ─── products ───────────────────────────────────────────────────
    // - Công khai: ai cũng xem được (không cần đăng nhập)
    // - Chỉ admin mới thêm/sửa/xóa sản phẩm
    match /products/{productId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // ─── orders ─────────────────────────────────────────────────────
    // - Chỉ người đặt thuê hoặc admin mới xem đơn
    // - Tất cả user đã đăng nhập có thể tạo đơn mới
    // - User chỉ được hủy đơn của mình (status -> "cancelled")
    // - Admin có toàn quyền
    match /orders/{orderId} {
      allow read: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated();
      allow update: if isAdmin() ||
        (isAuthenticated() &&
         resource.data.userId == request.auth.uid &&
         request.resource.data.status == 'cancelled' &&
         resource.data.status == 'pending');
      allow delete: if isAdmin();
    }

    // ─── reviews ────────────────────────────────────────────────────
    // - Công khai: ai cũng xem được đánh giá
    // - User đã đăng nhập có thể tạo đánh giá
    // - Chỉ tác giả mới sửa/xóa đánh giá của mình
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
    }

    // ─── favorites ──────────────────────────────────────────────────
    // - Chỉ chủ tài khoản mới xem/sửa danh sách yêu thích của mình
    match /favorites/{userId}/items/{productId} {
      allow read, write: if isOwner(userId);
    }

    // ─── carts ──────────────────────────────────────────────────────
    // - Chỉ chủ tài khoản mới xem/sửa giỏ hàng của mình
    match /carts/{userId} {
      allow read, write: if isOwner(userId);
    }

    // ─── branches ───────────────────────────────────────────────────
    // - Công khai: ai cũng xem được chi nhánh
    // - Chỉ admin mới thêm/sửa/xóa chi nhánh
    match /branches/{branchId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();

      // Inventory subcollection
      match /inventory/{productId} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }
  }
}
